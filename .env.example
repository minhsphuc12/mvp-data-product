# Postgres — source 1 (lending)
SOURCE_DB_1_HOST=localhost
SOURCE_DB_1_PORT=5433
SOURCE_DB_1_USER=demo
SOURCE_DB_1_PASSWORD=demo
SOURCE_DB_1_DATABASE=lending_db

# Postgres — source 2 (insurance)
SOURCE_DB_2_HOST=localhost
SOURCE_DB_2_PORT=5434
SOURCE_DB_2_USER=demo
SOURCE_DB_2_PASSWORD=demo
SOURCE_DB_2_DATABASE=insurance_db

# Postgres — analytics / warehouse
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=5435
ANALYTICS_DB_USER=demo
ANALYTICS_DB_PASSWORD=demo
ANALYTICS_DB_DATABASE=analytics_db

# Used by Python loaders and dbt (finance_demo profile)
ANALYTICS_DATABASE_URL=postgresql://demo:demo@localhost:5435/analytics_db

# Read-only login for Metabase / BI (schemas marts + semantic). Created by: make analytics-bootstrap-bi
ANALYTICS_DB_USER_BI=metabase_business
ANALYTICS_DB_PASSWORD_BI=change_me_strong_password

# Metabase (docker compose --profile bi up -d). Browser: http://localhost:<METABASE_PORT>
# In Metabase "Add database": host analytics_db, port 5432, database analytics_db, user ANALYTICS_DB_USER_BI / password ANALYTICS_DB_PASSWORD_BI (Compose network).
METABASE_PORT=3000

# Apache Airflow (docker compose --profile airflow up -d). UI: http://localhost:<AIRFLOW_WEBSERVER_PORT> (admin / admin)
AIRFLOW_WEBSERVER_PORT=8080
